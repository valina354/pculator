# Generated by ./configure from Makefile.in

CC ?= @CC@
CXX ?= @CXX@
OBJC ?= @OBJC@

PROGRAM ?= @PROGRAM@
HOST_OS := @HOST_OS@

USE_NUKED_OPL := @USE_NUKED_OPL@
USE_PCAP := @USE_PCAP@
USE_NUKLEAR := @USE_NUKLEAR@
NFD_BACKEND := @NFD_BACKEND@
NFD_WAYLAND := @NFD_WAYLAND@
FRONTEND_BACKENDS := @FRONTEND_BACKENDS@
DEFAULT_FRONTEND := @DEFAULT_FRONTEND@

CPPFLAGS ?= @CPPFLAGS@
CFLAGS ?= @CFLAGS@
CXXFLAGS ?= @CXXFLAGS@
OBJCFLAGS ?= @OBJCFLAGS@
LDFLAGS ?= @LDFLAGS@
LDLIBS ?= @LDLIBS@

BUILD_DIR ?= build
OBJDIR ?= $(BUILD_DIR)/obj

NFD_GENERATED_DIR := @NFD_GENERATED_DIR@
NFD_GENERATED_HDR := @NFD_GENERATED_HDR@
NFD_GENERATED_SRC := @NFD_GENERATED_SRC@
WAYLAND_SCANNER ?= @WAYLAND_SCANNER@
WAYLAND_PROTOCOL_XDG_FOREIGN := @WAYLAND_PROTOCOL_XDG_FOREIGN@

BASE_CSRCS = \
	src/args.c \
	src/chipset/dma.c \
	src/chipset/fdc37c665.c \
	src/chipset/i430fx.c \
	src/chipset/i430hx.c \
	src/chipset/i8042.c \
	src/chipset/i8253.c \
	src/chipset/i8255.c \
	src/chipset/i8257.c \
	src/chipset/i8259.c \
	src/chipset/intel_flash.c \
	src/chipset/piix.c \
	src/chipset/uart.c \
	src/chipset/w83877.c \
	src/chipset/cmosrtc.c \
	src/cpu/cpu.c \
	src/cpu/tinyfpu.c \
	src/debuglog.c \
	src/frontends/frontend.c \
	src/machine.c \
	src/main.c \
	src/memory.c \
	src/audio/blaster.c \
	src/audio/frontendaudio.c \
	src/audio/nukedopl.c \
	src/audio/opl2.c \
	src/audio/pcspeaker.c \
	src/disk/ata.c \
	src/disk/atapi_cdrom.c \
	src/disk/fdd.c \
	src/disk/fdd_img.c \
	src/disk/fdc.c \
	src/disk/fifo.c \
	src/input/kbc_at_device.c \
	src/input/keyboard_at.c \
	src/input/mouse.c \
	src/io/ne2000.c \
	src/io/rtl8139.c \
	src/scsi/buslogic.c \
	src/scsi/scsi.c \
	src/scsi/scsi_cdrom.c \
	src/scsi/scsi_device.c \
	src/scsi/scsi_disk.c \
	src/video/gd5440.c \
	src/video/vga.c \
	src/pci.c \
	src/ports.c \
	src/timing.c \
	src/utility.c

PCAP_CSRCS =
ifeq ($(USE_PCAP),yes)
PCAP_CSRCS += src/io/pcap.c
endif

FRONTEND_CSRCS = @FRONTEND_CSRCS@
HOST_CSRCS = @HOST_CSRCS@
EXTRA_CSRCS = @EXTRA_CSRCS@
CSRCS = $(BASE_CSRCS) $(PCAP_CSRCS) $(FRONTEND_CSRCS) $(HOST_CSRCS) $(EXTRA_CSRCS)

CXXSRCS = @CXXSRCS@
OBJCSRCS = @OBJCSRCS@

COBJS := $(patsubst %.c,$(OBJDIR)/%.o,$(CSRCS))
CXXOBJS := $(patsubst %.cpp,$(OBJDIR)/%.o,$(CXXSRCS))
OBJCOBJS := $(patsubst %.m,$(OBJDIR)/%.o,$(OBJCSRCS))
OBJS := $(COBJS) $(CXXOBJS) $(OBJCOBJS)
DEPS := $(OBJS:.o=.d)

LINK := $(CC)
ifneq ($(strip $(CXXSRCS)),)
LINK := $(CXX)
endif

.PHONY: all clean distclean print-config

all: $(BUILD_DIR)/$(PROGRAM)

print-config:
	@echo "Host OS           : $(HOST_OS)"
	@echo "USE_NUKED_OPL     : $(USE_NUKED_OPL)"
	@echo "USE_PCAP          : $(USE_PCAP)"
	@echo "USE_NUKLEAR       : $(USE_NUKLEAR)"
	@echo "NFD backend       : $(NFD_BACKEND)"
	@echo "NFD Wayland       : $(NFD_WAYLAND)"
	@echo "Frontends         : $(FRONTEND_BACKENDS)"
	@echo "Default frontend  : $(DEFAULT_FRONTEND)"
	@echo "Output            : $(BUILD_DIR)/$(PROGRAM)"

$(BUILD_DIR)/$(PROGRAM): $(OBJS)
	@mkdir -p $(dir $@)
	$(LINK) $(LDFLAGS) -o $@ $(OBJS) $(LDLIBS)

$(OBJDIR)/%.o: %.c
	@mkdir -p $(dir $@)
	$(CC) $(CPPFLAGS) $(CFLAGS) -MMD -MP -c $< -o $@

$(OBJDIR)/%.o: %.cpp
	@mkdir -p $(dir $@)
	$(CXX) $(CPPFLAGS) $(CXXFLAGS) -MMD -MP -c $< -o $@

$(OBJDIR)/%.o: %.m
	@mkdir -p $(dir $@)
	$(OBJC) $(CPPFLAGS) $(OBJCFLAGS) -MMD -MP -c $< -o $@

ifneq ($(strip $(NFD_GENERATED_SRC)),)
$(NFD_GENERATED_HDR): $(WAYLAND_PROTOCOL_XDG_FOREIGN)
	@mkdir -p $(dir $@)
	$(WAYLAND_SCANNER) client-header < $< > $@

$(NFD_GENERATED_SRC): $(WAYLAND_PROTOCOL_XDG_FOREIGN)
	@mkdir -p $(dir $@)
	$(WAYLAND_SCANNER) private-code < $< > $@

$(CXXOBJS): $(NFD_GENERATED_HDR)
$(OBJDIR)/$(NFD_GENERATED_SRC:.c=.o): $(NFD_GENERATED_HDR)
endif

clean:
	rm -rf $(BUILD_DIR)

distclean: clean
	rm -f Makefile

-include $(DEPS)
